  "keyFeatures": [
    "OpenGL ES 2, 3, 3.1, 3.2 and Metal display setup",
    "Cross-platform: iOS, tvOS, Android, WebGL (Emscripten)",
    "Touch, mouse, and keyboard input events",
    "Hardware sensor support: accelerometer, magnetometer, gyroscope",
    "Retina / high-DPI display support",
    "Application lifecycle and focus events",
    "OpenGL context loss handling",
    "Virtual keyboard and clipboard support",
    "Haptic feedback (iOS/Android)",
    "Safe area / chrome insets support"
